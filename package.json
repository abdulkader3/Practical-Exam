{
  "name": "ok_backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleFileExtensions": ["js", "mjs"],
    "extensionsToTreatAsEsm": [".js"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "tsc --noEmit",
    "worker": "node --loader ts-node/esm src/worker/bootstrap.ts",
    "worker:dev": "nodemon --exec node --loader ts-node/esm src/worker/bootstrap.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration",
    "test:e2e": "node tests/e2e/smoke.test.js",
    "test:quick": "echo 'Tests skipped - run npm test for full suite'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"src/**/*.ts\"",
    "check-env": "node src/config/env-validator.js",
    "migrate": "node src/db/migrations/migrate.js",
    "seed": "node src/db/seed.js",
    "prepare": "husky install",
    "coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "audit": "npm audit"
  },
  "author": "Abdul Kader",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.6.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.0",
    "multer": "^2.0.2",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
